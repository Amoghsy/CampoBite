spring.application.name=
server.port=8082
spring.datasource.url=
spring.datasource.username=
spring.datasource.password=

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

jwt.secret=
razorpay.key.id=
    razorpay.key.secret=

# Google OAuth
google.client.id=
spring.mail.host=
spring.mail.port=587
spring.mail.username=
spring.mail.password=
spring.mail.properties.mail.smtp.auth=
spring.mail.properties.mail.smtp.starttls.enable=
admin.email=


razorpay.webhook.secret=


# Google Apps Script OTP Email
google.script.url=
google.script.secret=





# ===== Gemini AI Chatbot Configuration =====
gemini.api.key=
gemini.api.timeout=10

# ===== Chatbot Rate Limiting =====
chatbot.rate-limit.max-requests=20
chatbot.rate-limit.window-seconds=60

# ===== Chat History =====
chatbot.history.max-messages=10
